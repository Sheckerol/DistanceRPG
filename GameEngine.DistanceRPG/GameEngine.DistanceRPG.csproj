<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AssemblyName>DistanceRPG</AssemblyName>
        <RootNamespace>GameEngine.DistanceRPG</RootNamespace>
        <RuntimeIdentifiers>win-x64;linux-x64</RuntimeIdentifiers>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="GameEngine.DistanceRPG.Tests" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="OpenTK" Version="4.9.4"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\GameEngine\GameEngine.Core\GameEngine.Core.csproj"/>
    </ItemGroup>

    <!-- Copy engine shaders from Core so they're available at runtime -->
    <ItemGroup>
        <Content Include="..\..\GameEngine\GameEngine.Core\Shaders\**\*"
                 Link="Shaders\%(RecursiveDir)%(Filename)%(Extension)"
                 CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>

</Project>
